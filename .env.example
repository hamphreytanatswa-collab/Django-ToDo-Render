# Django Settings
SECRET_KEY=replace-this-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=your-render-app.onrender.com,localhost,127.0.0.1

# Render provides DATABASE_URL automatically when you attach a Postgres database.
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Optional demo login user created during deploy and prefilled on the login page
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=replace-this-password
